meta {
  name: DIGIweb Licenses
}

auth {
  mode: oauth2
}

auth:oauth2 {
  grant_type: authorization_code
  callback_url: {{baseUrl}}
  authorization_url: {{license-auth-url}}
  access_token_url: {{license-oidc}}
  refresh_token_url: 
  client_id: {{license-client-id}}
  client_secret: 
  scope: email
  state: 
  pkce: false
  credentials_placement: basic_auth_header
  credentials_id: 
  token_placement: header
  token_header_prefix: 
  auto_fetch_token: true
  auto_refresh_token: false
}
