meta {
  name: Access token
  type: http
  seq: 11
}

post {
  url: {{keycloak-server-url}}/realms/skypro/protocol/openid-connect/token
  body: formUrlEncoded
  auth: basic
}

auth:basic {
  username: {{keycloak-client-id}}
  password: {{keycloak-client-secret}}
}

body:form-urlencoded {
  grant_type: client_credentials
}

settings {
  encodeUrl: true
}
