meta {
  name: /v1/third-party/tray test Salling
  type: http
  seq: 2
}

post {
  url: {{thirdparty}}/api/v1/third-party/tray
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
      "traystoreno": 0,
      "traydepartmentno": 1,
      "trayno": {{trayno}},
      "trayname": "tray {{trayno}}",
      "traytare": 0,
      "traywrappertare": 0,
      "traywrappertype": "tray wrapper type {{trayno}}"
  }
}

script:pre-request {
  var trayno = bru.getEnvVar("trayno");
  // var newTraceType = 2;
  
  trayno = parseInt(trayno) + 1;
  
  // if(pluno == 10){
  // //     pm.environment.set("newTraceType",newTraceType);
  // }
  
  bru.setEnvVar("trayno",trayno);
}

settings {
  encodeUrl: true
}
