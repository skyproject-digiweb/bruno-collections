script:pre-request {
  var pluno = bru.getEnvVar("pluno");
  // var newTraceType = 2;
  
  pluno = parseInt(pluno) + 1;
  
  // if(pluno == 10){
  // //     pm.environment.set("newTraceType",newTraceType);
  // }
  
  bru.setEnvVar("pluno",pluno);
}

