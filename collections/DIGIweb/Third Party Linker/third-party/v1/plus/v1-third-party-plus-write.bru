meta {
  name: /v1/third-party/plus/write
  type: http
  seq: 4
}

post {
  url: {{thirdparty}}/api/v1/third-party/plus/write
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
      "storeno": 0,
      "pluno": 4,
      "pludepartmentno": 1,
      "plugroupno": 1,
      "plubarcoderefno": "22",
      "plubarcodedata": "1234567",
      "plucommname": "Ground Beef 3",
      "pluunitprice": 0,
      "plutexts": [
          {
              "plutextindex": 1,
              "plutextval": "Bedst før"
          }
      ],
      "pluingredients": "Line 1 Steges"
  }
}

script:pre-request {
  var pluno = bru.getEnvVar("pluno");
  // var newTraceType = 2;
   
  pluno = parseInt(pluno) + 1;
   
  // if(pluno == 10){
  // //     pm.environment.set("newTraceType",newTraceType);
  // }
   
  bru.setEnvVar("pluno",pluno);
}

settings {
  encodeUrl: true
}
